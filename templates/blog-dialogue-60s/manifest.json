      "pose": "explain",
      "emphasis": [
        "途中の考え",
        "少し"
      ],
      "visual": {
        "kicker": "ANTHROPIC RESEARCH",
        "headline": "沈黙した途中の考え",
        "detail": "全部ではなく、一部を観察できるかもしれない",
        "badges": [
          "出力前",
          "観察"
        ]
