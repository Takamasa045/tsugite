{
  "name": "@tsugite/download-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/run-vinext.mjs dev",
    "build": "node scripts/run-vinext.mjs build",
    "start": "node scripts/run-vinext.mjs start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs tests/dependency-security.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "security:audit": "npm audit --omit=dev --audit-level=moderate && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "next": "^16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "brace-expansion": "5.0.8",
    "minimatch": "10.2.5",
    "fast-uri": "3.1.4",
    "js-yaml": "4.3.0",
    "postcss": "8.5.21",
    "react-server-dom-webpack": "19.2.8",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.11",
    "react-server-dom-webpack": "19.2.8",
    "tailwindcss": "^4.3.3",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "type": "module"
}
