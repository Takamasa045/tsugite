{
  "name": "tsugite",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "bin": {
    "pipeline": "./bin/pipeline"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude='apps/**'",
    "test:coverage": "vitest run --exclude='apps/**' --coverage --coverage.include='src/**/*.ts' --coverage.thresholds.statements=80 --coverage.thresholds.branches=80 --coverage.thresholds.functions=80 --coverage.thresholds.lines=80",
    "viewer:dev": "npm --prefix apps/workflow-viewer run dev",
    "viewer:open": "bin/pipeline viewer-launcher --open",
    "viewer:check": "npm --prefix apps/workflow-viewer run test:coverage && npm --prefix apps/workflow-viewer run typecheck",
    "viewer:build": "npm --prefix apps/workflow-viewer run build",
    "vendor:check": "node scripts/check-vendor-boundary.mjs",
    "check": "npm run vendor:check && npm run build && npm run test:coverage"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.487",
    "@remotion/renderer": "^4.0.486",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.486",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.7",
    "hyperframes": "^0.7.46",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.7"
  }
}
