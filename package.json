{
  "name": "tsugite",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.12 <23",
    "npm": ">=10"
  },
  "bin": {
    "pipeline": "./bin/pipeline"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude=\"apps/**\"",
    "test:coverage": "vitest run --exclude=\"apps/**\" --coverage --coverage.include=\"src/**/*.ts\" --coverage.thresholds.statements=80 --coverage.thresholds.branches=75 --coverage.thresholds.functions=80 --coverage.thresholds.lines=80",
    "pipeline": "node bin/pipeline",
    "viewer:dev": "npm --prefix apps/workflow-viewer run dev",
    "viewer:open": "node bin/pipeline viewer-launcher --open",
    "viewer:check": "npm --prefix apps/workflow-viewer run test:coverage && npm --prefix apps/workflow-viewer run typecheck",
    "viewer:build": "npm --prefix apps/workflow-viewer run build",
    "vendor:check": "node scripts/check-vendor-boundary.mjs",
    "check": "npm run vendor:check && npm run build && npm run test:coverage"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.490",
    "@remotion/renderer": "^4.0.490",
    "cross-spawn": "^7.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.486",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "hyperframes": "^0.7.46",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10"
  }
}
